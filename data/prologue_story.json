    "prologue": [
      {
        "type": "narration",
        "text": "（门锁转动的声音）"
      },
      {
        "type": "narration",
        "text": "我推开公寓的门，屋子里弥漫着一股淡淡的、有些陌生的消毒水味，混合着一丝少女的幽香。"
      },
      {
        "type": "narration",
        "text": "在疗养院住了那么久的表妹，今天起就要搬来和我一起住了。"
      },
      {
        "type": "say",
        "speaker": "维多利亚",
        "text": "哥哥……那个，好久不见。以后就要麻烦你照顾了。"
      },
      {
        "type": "say",
        "speaker": "维多利亚",
        "text": "虽然医生说我的身体已经好得差不多了，但很多事情可能还是会反应慢一点，哥哥不会嫌弃我吧？"
      },
      {
        "type": "choice",
        "choices": [
          {
            "text": "“当然不会，欢迎回家。”",
            "effects": {
              "love_score": 5
            },
            "next": "prologue_welcome"
          },
          {
            "text": "“只要你别添乱就行。”",
            "effects": {
              "love_score": 0
            },
            "next": "prologue_harsh"
          }
        ]
      }
    ],
    "prologue_welcome": [
      {
        "type": "say",
        "speaker": "维多利亚",
        "text": "（她露出了一个极其标准的微笑）嗯！谢谢哥哥。"
      },
